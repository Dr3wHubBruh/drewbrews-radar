{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DrewBrews Trend Radar feed",
  "description": "Contract between scout.mjs (writer) and the DrewBrews Trend Studio (reader). v1.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "trends"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "trends": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["name", "buzz", "tpl", "src"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 80 },
          "src": { "type": "string", "enum": ["press", "review", "community", "verify"] },
          "buzz": { "type": "string", "minLength": 1, "maxLength": 400 },
          "tpl": { "type": "string", "enum": ["s1", "s2", "s3", "s4", "s5", "s6"] },
          "angle": { "type": "string", "maxLength": 400 },
          "source_url": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
